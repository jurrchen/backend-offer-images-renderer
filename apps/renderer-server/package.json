{
  "name": "@fourthwall/renderer-server",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Headless Node.js rendering service for Fourthwall product renderer",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "dev": "npm run build && tsx watch src/server.ts",
    "native": "./run-native.sh",
    "build": "tsc && npm run build:worker",
    "build:worker": "node scripts/build-worker.mjs",
    "build:bundle": "esbuild src/server.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/server.bundle.cjs --external:canvas --external:gl --external:sharp --banner:js=\"const import_meta_url = require('url').pathToFileURL(__filename).href;\"  --define:import.meta.url=import_meta_url",
    "start": "node dist/server.js",
    "start:bundle": "node dist/server.bundle.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fourthwall/product-renderer": "1.0.0-rc3",
    "@fourthwall/shared": "*",
    "@google-cloud/pubsub": "^4.11.0",
    "@google-cloud/storage": "^7.19.0",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.8.0",
    "fastify-type-provider-zod": "^6.1.0",
    "lodash-es": "4.17.21",
    "lru-cache": "^10.4.3",
    "openapi-types": "^12.1.3",
    "pg": "^8.19.0",
    "pg-boss": "^9.0.3",
    "prom-client": "^15.1.0",
    "sharp": "^0.33.1",
    "three": "^0.158.0",
    "tsx": "^4.7.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@fourthwall/typescript-config": "*",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.16.0",
    "@types/pngjs": "^6.0.5",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "drizzle-kit": "^0.30.0",
    "esbuild": "^0.27.2",
    "eslint": "^8.56.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "puppeteer": "^24.37.2",
    "typescript": "^5.3.3",
    "vitest": "^1.1.1"
  },
  "optionalDependencies": {
    "canvas": "^2.11.2",
    "gl": "^8.1.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
