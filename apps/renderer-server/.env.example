# ─── Environment ──────────────────────────────────────────────────────────────
# Determines storage backends, GCP project, Pub/Sub, bucket names, etc.
# Values: local (default) | staging | prod
# See src/config/environments.ts for per-environment defaults.
ENVIRONMENT=local

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=debug

# ─── Auth ────────────────────────────────────────────────────────────────────
# API key for protected endpoints (empty = no auth, for local dev)
API_KEY=

# ─── Renderer ─────────────────────────────────────────────────────────────────
CANVAS_SIZE=2048

# ─── Worker Pool ──────────────────────────────────────────────────────────────
WORKER_COUNT=1               # ~300MB RSS per worker
JOB_TIMEOUT=120000           # Job timeout in ms
NODE_HEAP_LIMIT_MB=512       # V8 --max-old-space-size per worker
MAX_RESPAWNS=5               # Max respawns before permanent failure
MAX_JOBS_PER_WORKER=25       # Restart worker every N jobs (0 = disabled)
MAX_QUEUE_DEPTH=500          # Return 503 if queue exceeds this

# ─── Database (pg-boss + Drizzle analytics) ───────────────────────────────────
# Omit to disable persistent jobs and analytics
DATABASE_URL=postgresql://renderer:renderer_dev@localhost:5432/offer-renderer

# ─── Job Queue (pg-boss) ─────────────────────────────────────────────────────
JOB_RETRY_LIMIT=0
JOB_EXPIRE_SECONDS=1800
JOB_ARCHIVE_AFTER_SECONDS=604800

# ─── Local Storage ────────────────────────────────────────────────────────────
# Set to save renders to disk + enable SSE stream (overrides GCS in local env)
LOCAL_OUTPUT_DIR=./output

# ─── Analytics ────────────────────────────────────────────────────────────────
# Override auto-detected server URL for analytics records
# Optional — defaults to http://localhost:{PORT}
SERVER_URL=
